{
  "_comment": "DMS 客户端构建配置文件 - 复制此文件为 build_config.json 并修改相应参数",
  "_comment2": "授权配置在 license section 中维护，构建时自动生成 dms_license_config.json 并打包",

  "build": {
    "entry_script": "desktop_launcher.py",
    "output_name": "DMS_Client",
    "windowed": true
  },
  "license": {
    "mode": "free",
    "name": "",
    "days": 0,
    "expires": null,
    "required": false,
    "build_time": null
  },
  "sign": {
    "enabled": false,
    "cert_thumbprint": "",
    "cert_pfx_path": "",
    "cert_pfx_password": "",
    "timestamp_url": "http://timestamp.digicert.com"
  }
}
