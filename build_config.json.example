{
  "_comment": "DMS 客户端构建配置文件 - 请根据需要修改以下配置",
  "_comment2": "复制此文件为 build_config.json 并修改相应参数",

  "license": {
    "name": "Default",
    "days": 365,
    "expires": null,
    "required": false
  },
  "build": {
    "entry_script": "desktop_launcher.py",
    "output_name": "DMS_Client",
    "windowed": true
  },
  "sign": {
    "enabled": false,
    "cert_thumbprint": "",
    "cert_pfx_path": "",
    "cert_pfx_password": "",
    "timestamp_url": "http://timestamp.digicert.com"
  }
}
